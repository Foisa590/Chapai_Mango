# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY


# ──────────────────────────────────────────────────────────────────
# Payment methods — receiving numbers + per-method fixed advance
# ──────────────────────────────────────────────────────────────────
# Two env vars per method, both optional:
#
#   NEXT_PUBLIC_<CODE>_NUMBER    receiving MFS number / bank account text
#   NEXT_PUBLIC_<CODE>_ADVANCE   fixed BDT amount the customer must pay
#                                up front before the order ships (0 =
#                                no advance required)
#
# Behaviour rules used by /checkout:
#   * advance > 0           -> customer sends `advance` now, rest paid
#                              on delivery (typical COD-with-deposit
#                              flow)
#   * advance = 0  + COD    -> classic COD, full amount on delivery
#   * advance = 0  + online -> full order total paid up front
#
# Codes accepted: cod, bkash, nagad, rocket, upay, bank.

# bKash (mobile financial service)
NEXT_PUBLIC_BKASH_NUMBER=01XXXXXXXXX
# NEXT_PUBLIC_BKASH_ADVANCE=0

# Nagad (mobile financial service)
NEXT_PUBLIC_NAGAD_NUMBER=01XXXXXXXXX
# NEXT_PUBLIC_NAGAD_ADVANCE=0

# Rocket (Dutch-Bangla Bank mobile)
NEXT_PUBLIC_ROCKET_NUMBER=01XXXXXXXXX
# NEXT_PUBLIC_ROCKET_ADVANCE=0

# Upay (United Commercial Bank mobile)
# NEXT_PUBLIC_UPAY_NUMBER=01XXXXXXXXX
# NEXT_PUBLIC_UPAY_ADVANCE=0

# Bank transfer — split into FOUR structured fields so you can edit
# any one without re-keying the rest. Defaults are seeded with the
# operator's current AB BANK / RAJSHAHI account; account number is
# blank and MUST be filled in (the checkout form shows an explicit
# warning until it's set).
NEXT_PUBLIC_BANK_HOLDER=MD FOISAL IQBAL
NEXT_PUBLIC_BANK_NAME=AB BANK
NEXT_PUBLIC_BANK_BRANCH=RAJSHAHI
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=
# NEXT_PUBLIC_BANK_ADVANCE=0

# Legacy single-line bank string. ONLY used when set — it overrides
# the four structured fields above for the receipt summary line.
# Leave commented out unless you have a reason to keep the old format.
# NEXT_PUBLIC_BANK_NUMBER=DBBL · A/C 1234567890 · Branch X

# Cash on delivery doesn't have a number, but you can still set an
# advance (booking deposit) that the customer pays via any other
# method — set NEXT_PUBLIC_COD_ADVANCE=100 and explain in your COD
# instructions which number to send the deposit to.
# NEXT_PUBLIC_COD_ADVANCE=0

# Comma-separated list of payment method codes to show on /checkout.
# All six are shown by default. Use this to hide one without removing
# its env vars (handy during outages).
#   Examples:
#     cod,bkash,nagad,rocket,upay,bank   (default)
#     bkash,nagad                        (only bKash + Nagad)
#     cod,bkash                          (turn rest off)
# NEXT_PUBLIC_PAYMENT_METHODS=cod,bkash,nagad,rocket,upay,bank


# Business contact info
NEXT_PUBLIC_BUSINESS_PHONE=01XXXXXXXXX
NEXT_PUBLIC_BUSINESS_EMAIL=hello@chapaimangohouse.com

# ──────────────────────────────────────────────────────────────────
# Google Map (Contact page)
# ──────────────────────────────────────────────────────────────────
# Latitude + longitude for the pin on /contact. No API key needed.
# Defaults below land on Nachole, Chapainawabganj. To get exact coords:
#   1) Open Google Maps, right-click on your bagaan/office.
#   2) Click the "lat, lng" line at the top — it copies to clipboard.
#   3) Paste them here as separate values.
#
# NEXT_PUBLIC_BUSINESS_MAP_LAT=24.7011
# NEXT_PUBLIC_BUSINESS_MAP_LNG=88.3500
# NEXT_PUBLIC_BUSINESS_MAP_LABEL=নিজামপুর, নাচোল, চাঁপাইনবাবগঞ্জ

# Social profiles (shown in footer)
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/share/1E8A9tnY4U/
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@chapai_mango

# ──────────────────────────────────────────────────────────────────
# Delivery toggles
# ──────────────────────────────────────────────────────────────────
# Flat delivery fee in BDT. Set to 0 to make delivery ALWAYS FREE.
# Default: 120
# NEXT_PUBLIC_DELIVERY_FEE=120

# Cart subtotal at or above which delivery becomes free.
# Set to 0 to never auto-waive (always charge the fee).
# Default: 2000
# NEXT_PUBLIC_FREE_DELIVERY_OVER=2000

# Minimum total kilograms across all cart items required to place an order.
# Set to 0 to disable the minimum.
# Default: 10
# NEXT_PUBLIC_MIN_ORDER_KG=10


# ──────────────────────────────────────────────────────────────────
# Google sign-in (Supabase OAuth)
# ──────────────────────────────────────────────────────────────────
# Google login uses Supabase's built-in OAuth flow, so there are NO
# extra env vars to set in this file. Setup is done in the Supabase
# Dashboard + Google Cloud Console:
#
# 1) Google Cloud Console -> APIs & Services -> Credentials ->
#    Create OAuth client ID (type: Web application).
#       Authorized redirect URI:
#         https://YOUR-PROJECT.supabase.co/auth/v1/callback
#
# 2) Copy the Client ID + Client Secret into Supabase Dashboard ->
#    Authentication -> Providers -> Google. Enable the provider.
#
# 3) Supabase Dashboard -> Authentication -> URL Configuration ->
#    add every site origin you use to "Redirect URLs":
#         http://localhost:3000/auth/callback
#         https://your-production-domain.com/auth/callback
#
# After that the "Google দিয়ে চালিয়ে যান" button on /login and
# /signup will just work.



# ──────────────────────────────────────────────────────────────────
# SEO / Search Engine setup
# ──────────────────────────────────────────────────────────────────
# Public, canonical URL of the site. Used to build absolute URLs in
# sitemap.xml, robots.txt, JSON-LD structured data and Open Graph tags.
# Set this in your hosting provider (Railway/Vercel) to your real
# domain. NO trailing slash.
#
# Examples:
#   https://chapaimangohouse.com
#   https://www.dealhub2026.shop
#
# If unset, the app falls back to RAILWAY_PUBLIC_DOMAIN, then VERCEL_URL,
# then http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://www.dealhub2026.shop

# Google Search Console verification.
#
# We support TWO methods (you only need ONE verified):
#
#   1) DNS TXT record (preferred for custom domains)
#      Add this to your DNS zone (the same place you put the
#      Railway CNAME):
#        Type:  TXT
#        Name:  @
#        Value: google-site-verification=<token-from-search-console>
#
#      No env var needed for this method. Once Search Console
#      validates the TXT record, you're verified — and the
#      verification persists as long as the record stays in DNS.
#
#   2) HTML meta tag (works for any host)
#      Set this env var to the "content" value of the Search
#      Console <meta> tag. The app will render
#      <meta name="google-site-verification" content="..." /> in
#      every page <head>.
#      NOTE: app/layout.tsx ships with a hard-coded fallback of
#      9l1HBSx0SpXFJUDl4Eq4YJ2CoOPA41pJO04mTiEd_20 (the operator's
#      current Search Console token), so HTML-tag verification works
#      out of the box even without setting the env var. Override here
#      if you regenerate the token in Search Console.
#
# Both methods can be active at once for belt-and-braces.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# (Optional) Bing Webmaster Tools verification, "msvalidate.01" content.
# NEXT_PUBLIC_BING_SITE_VERIFICATION=



# ──────────────────────────────────────────────────────────────────
# WhatsApp floating button
# ──────────────────────────────────────────────────────────────────
# International format, digits only. e.g. 8801712345678
# (No "+" prefix.) If unset, falls back to NEXT_PUBLIC_BUSINESS_PHONE
# above (which we'll auto-prefix from "01XXX..." to "8801XXX..."). The
# button hides itself entirely when neither is set or the value still
# contains the "XXXXXXXXX" placeholder.
# NEXT_PUBLIC_WHATSAPP_NUMBER=8801712345678


# ──────────────────────────────────────────────────────────────────
# Web Push (admin -> /admin/notifications)
# ──────────────────────────────────────────────────────────────────
# Generate a fresh VAPID key pair locally:
#
#   npx web-push generate-vapid-keys
#
# Paste the public key into both server-side and NEXT_PUBLIC_ slots
# (the browser needs it as `applicationServerKey`). Keep the private
# key SECRET — never expose it to the client.
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY  is read by SubscribeButton on the
# client. If unset, the SubscribeButton renders nothing and broadcasts
# fail with a friendly error in the admin form.
#
# VAPID_SUBJECT must be a mailto: URL or https URL identifying the
# operator (used by the push services for abuse contact).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@chapaimangohouse.com


# ──────────────────────────────────────────────────────────────────
# Database migrations
# ──────────────────────────────────────────────────────────────────
# After deploying this app run the following Supabase SQL files in
# the SQL Editor (in any order — they are independent and idempotent):
#
#   supabase/reviews.sql            — product_reviews + recompute trigger
#   supabase/track-order.sql        — public order tracking RPC
#   supabase/push-subscriptions.sql — push subscriptions table
#   supabase/marquees.sql           — admin-managed top promo strip
#   supabase/team-members.sql       — admin-managed Founders/Suppliers/Team
#   supabase/payment-methods.sql    — drops the legacy IN-list check on
#                                     orders.payment_method so Upay /
#                                     Bank / future methods are accepted;
#                                     also tears down the unused
#                                     payment_methods table that an
#                                     earlier branch created.
#   supabase/refund-policy.sql      — single-row table holding the
#                                     Bangla refund policy markdown,
#                                     edited from /admin/refund-policy
#   supabase/security-fixes.sql     — Security Advisor fixes (run LAST)
#                                     · pins search_path on tg_reviews_recompute
#                                     · revokes EXECUTE from PUBLIC on
#                                       SECURITY DEFINER functions
#                                     · replaces every "using (true)" admin
#                                       RLS policy with is_admin()-gated
#                                       per-action policies
#                                     · converts anon DELETE on
#                                       push_subscriptions to the
#                                       unsubscribe_push() RPC (closes the
#                                       "any visitor can wipe the subscriber
#                                       table" CVE-class hole)
