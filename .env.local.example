# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Manual mobile financial service numbers (shown on checkout page)
NEXT_PUBLIC_BKASH_NUMBER=01XXXXXXXXX
NEXT_PUBLIC_NAGAD_NUMBER=01XXXXXXXXX
NEXT_PUBLIC_ROCKET_NUMBER=01XXXXXXXXX

# Business contact info
NEXT_PUBLIC_BUSINESS_PHONE=01XXXXXXXXX
NEXT_PUBLIC_BUSINESS_EMAIL=hello@chapaimangohouse.com

# Social profiles (shown in footer)
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/share/1E8A9tnY4U/
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@chapai_mango

# ──────────────────────────────────────────────────────────────────
# Delivery + payment toggles (operator can change anytime)
# ──────────────────────────────────────────────────────────────────
# Flat delivery fee in BDT. Set to 0 to make delivery ALWAYS FREE.
# Default: 120
# NEXT_PUBLIC_DELIVERY_FEE=120

# Cart subtotal at or above which delivery becomes free.
# Set to 0 to never auto-waive (always charge the fee).
# Default: 2000
# NEXT_PUBLIC_FREE_DELIVERY_OVER=2000

# Comma-separated list of payment methods to show on checkout.
# Allowed values: cod, bkash, nagad, rocket
# Examples:
#   cod,bkash,nagad,rocket  (default — all four shown)
#   bkash,nagad,rocket      (turn COD off)
#   bkash                   (only bKash)
# NEXT_PUBLIC_PAYMENT_METHODS=cod,bkash,nagad,rocket
