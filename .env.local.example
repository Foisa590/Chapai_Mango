# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Manual mobile financial service numbers (shown on checkout page)
NEXT_PUBLIC_BKASH_NUMBER=01XXXXXXXXX
NEXT_PUBLIC_NAGAD_NUMBER=01XXXXXXXXX
NEXT_PUBLIC_ROCKET_NUMBER=01XXXXXXXXX

# Business contact info
NEXT_PUBLIC_BUSINESS_PHONE=01XXXXXXXXX
NEXT_PUBLIC_BUSINESS_EMAIL=hello@chapaimangohouse.com

# Social profiles (shown in footer)
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/share/1E8A9tnY4U/
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@chapai_mango

# ──────────────────────────────────────────────────────────────────
# Delivery + payment toggles (operator can change anytime)
# ──────────────────────────────────────────────────────────────────
# Flat delivery fee in BDT. Set to 0 to make delivery ALWAYS FREE.
# Default: 120
# NEXT_PUBLIC_DELIVERY_FEE=120

# Cart subtotal at or above which delivery becomes free.
# Set to 0 to never auto-waive (always charge the fee).
# Default: 2000
# NEXT_PUBLIC_FREE_DELIVERY_OVER=2000

# Comma-separated list of payment methods to show on checkout.
# Allowed values: cod, bkash, nagad, rocket
# Examples:
#   cod,bkash,nagad,rocket  (default — all four shown)
#   bkash,nagad,rocket      (turn COD off)
#   bkash                   (only bKash)
# NEXT_PUBLIC_PAYMENT_METHODS=cod,bkash,nagad,rocket

# Minimum total kilograms across all cart items required to place an order.
# Set to 0 to disable the minimum.
# Default: 10
# NEXT_PUBLIC_MIN_ORDER_KG=10


# ──────────────────────────────────────────────────────────────────
# Google sign-in (Supabase OAuth)
# ──────────────────────────────────────────────────────────────────
# Google login uses Supabase's built-in OAuth flow, so there are NO
# extra env vars to set in this file. Setup is done in the Supabase
# Dashboard + Google Cloud Console:
#
# 1) Google Cloud Console -> APIs & Services -> Credentials ->
#    Create OAuth client ID (type: Web application).
#       Authorized redirect URI:
#         https://YOUR-PROJECT.supabase.co/auth/v1/callback
#
# 2) Copy the Client ID + Client Secret into Supabase Dashboard ->
#    Authentication -> Providers -> Google. Enable the provider.
#
# 3) Supabase Dashboard -> Authentication -> URL Configuration ->
#    add every site origin you use to "Redirect URLs":
#         http://localhost:3000/auth/callback
#         https://your-production-domain.com/auth/callback
#
# After that the "Google দিয়ে চালিয়ে যান" button on /login and
# /signup will just work.



# ──────────────────────────────────────────────────────────────────
# SEO / Search Engine setup
# ──────────────────────────────────────────────────────────────────
# Public, canonical URL of the site. Used to build absolute URLs in
# sitemap.xml, robots.txt, JSON-LD structured data and Open Graph tags.
# Set this in your hosting provider (Railway/Vercel) to your real
# domain. NO trailing slash.
#
# Examples:
#   https://chapaimangohouse.com
#   https://chapaimango-production.up.railway.app
#
# If unset, the app falls back to RAILWAY_PUBLIC_DOMAIN, then VERCEL_URL,
# then http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://chapaimango-production.up.railway.app

# Google Search Console verification code (the "content" value from the
# HTML tag method). Once your site is verified you can leave this set
# or remove it — both work.
#
# How to get it:
#   1) Go to https://search.google.com/search-console
#   2) Add property (URL prefix) -> use NEXT_PUBLIC_SITE_URL above
#   3) Choose "HTML tag" verification, copy the content value.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# (Optional) Bing Webmaster Tools verification, "msvalidate.01" content.
# NEXT_PUBLIC_BING_SITE_VERIFICATION=



# ──────────────────────────────────────────────────────────────────
# WhatsApp floating button
# ──────────────────────────────────────────────────────────────────
# International format, digits only. e.g. 8801712345678
# (No "+" prefix.) If unset, falls back to NEXT_PUBLIC_BUSINESS_PHONE
# above (which we'll auto-prefix from "01XXX..." to "8801XXX..."). The
# button hides itself entirely when neither is set or the value still
# contains the "XXXXXXXXX" placeholder.
# NEXT_PUBLIC_WHATSAPP_NUMBER=8801712345678


# ──────────────────────────────────────────────────────────────────
# Web Push (admin -> /admin/notifications)
# ──────────────────────────────────────────────────────────────────
# Generate a fresh VAPID key pair locally:
#
#   npx web-push generate-vapid-keys
#
# Paste the public key into both server-side and NEXT_PUBLIC_ slots
# (the browser needs it as `applicationServerKey`). Keep the private
# key SECRET — never expose it to the client.
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY  is read by SubscribeButton on the
# client. If unset, the SubscribeButton renders nothing and broadcasts
# fail with a friendly error in the admin form.
#
# VAPID_SUBJECT must be a mailto: URL or https URL identifying the
# operator (used by the push services for abuse contact).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@chapaimangohouse.com


# ──────────────────────────────────────────────────────────────────
# Database migrations
# ──────────────────────────────────────────────────────────────────
# After deploying this app run the following Supabase SQL files in
# the SQL Editor (in any order — they are independent and idempotent):
#
#   supabase/reviews.sql            — product_reviews + recompute trigger
#   supabase/track-order.sql        — public order tracking RPC
#   supabase/push-subscriptions.sql — push subscriptions table
